# ===========================================
# Aristo 东南亚美妆电商平台 - 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填写实际值
# ===========================================

# 数据库配置 (Supabase PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# S3 对象存储配置
S3_ENDPOINT=https://your-s3-endpoint
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=aristo-uploads

# AI 客服配置 (可选)
# OPENAI_API_KEY=your-openai-api-key
# COZE_API_KEY=your-coze-api-key

# 网站配置
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=Aristo Beauty
NEXT_PUBLIC_SITE_EMAIL=support@aristo-beauty.com
NEXT_PUBLIC_SITE_PHONE=+66 2 123 4567

# 翻译 API (MyMemory - 免费)
# NEXT_PUBLIC_TRANSLATION_API_KEY=your-mymemory-key
